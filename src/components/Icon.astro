---
interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = '', strokeWidth = 1.8 } = Astro.props;
---

<svg
  class:list={['icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'droplet' && (
    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0L12 2.69z" />
  )}
  {name === 'zap' && (
    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
  )}
  {name === 'moon' && (
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  )}
  {name === 'target' && (
    <Fragment>
      <circle cx="12" cy="12" r="10" />
      <circle cx="12" cy="12" r="6" />
      <circle cx="12" cy="12" r="2" />
    </Fragment>
  )}
  {name === 'leaf' && (
    <Fragment>
      <path d="M11 20A7 7 0 0 0 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10z" />
      <path d="M5.7 14.3C8.93 11.97 11.84 10.7 16.7 8.5" />
    </Fragment>
  )}
  {name === 'clock' && (
    <Fragment>
      <circle cx="12" cy="12" r="10" />
      <path d="M12 6v6l4 2" />
    </Fragment>
  )}
  {name === 'activity' && (
    <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
  )}
  {name === 'check-circle' && (
    <Fragment>
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
      <path d="M22 4L12 14.01l-3-3" />
    </Fragment>
  )}
  {name === 'battery' && (
    <Fragment>
      <rect x="1" y="6" width="18" height="12" rx="2" ry="2" />
      <path d="M23 13v-2" />
      <path d="M11 10l-3 3 3 3" />
      <path d="M8 13h6" />
    </Fragment>
  )}
  {name === 'dumbbell' && (
    <Fragment>
      <path d="M6.5 6.5h11v11h-11z" stroke="none" fill="none" />
      <path d="M17.5 7.5L17.5 16.5" />
      <path d="M6.5 7.5L6.5 16.5" />
      <path d="M6.5 12L17.5 12" />
      <path d="M20 9L20 15" />
      <path d="M4 9L4 15" />
    </Fragment>
  )}
  {name === 'bed' && (
    <Fragment>
      <path d="M2 4v16" />
      <path d="M2 8h18a2 2 0 0 1 2 2v10" />
      <path d="M2 17h20" />
      <path d="M6 8v2a2 2 0 0 0 2 2h0a2 2 0 0 0 2-2V8" />
    </Fragment>
  )}
  {name === 'monitor-off' && (
    <Fragment>
      <path d="M17 17H4a2 2 0 0 1-2-2V5c0-1.1.9-2 2-2h16a2 2 0 0 1 2 2v5" />
      <path d="M8 21h8" />
      <path d="M12 17v4" />
      <path d="M2 2l20 20" />
    </Fragment>
  )}
  {name === 'wind' && (
    <Fragment>
      <path d="M9.59 4.59A2 2 0 1 1 11 8H2" />
      <path d="M12.59 19.41A2 2 0 1 0 14 16H2" />
      <path d="M17.73 7.73A2.5 2.5 0 1 1 19.5 12H2" />
    </Fragment>
  )}
  {name === 'chevron-down' && (
    <path d="M6 9l6 6 6-6" />
  )}
  {name === 'arrow-down' && (
    <Fragment>
      <path d="M12 5v14" />
      <path d="M19 12l-7 7-7-7" />
    </Fragment>
  )}
  {name === 'repeat' && (
    <Fragment>
      <path d="M17 1l4 4-4 4" />
      <path d="M3 11V9a4 4 0 0 1 4-4h14" />
      <path d="M7 23l-4-4 4-4" />
      <path d="M21 13v2a4 4 0 0 1-4 4H3" />
    </Fragment>
  )}
  {name === 'shield' && (
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
  )}
  {name === 'trending-up' && (
    <Fragment>
      <path d="M23 6l-9.5 9.5-5-5L1 18" />
      <path d="M17 6h6v6" />
    </Fragment>
  )}
  {name === 'eye' && (
    <Fragment>
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
      <circle cx="12" cy="12" r="3" />
    </Fragment>
  )}
  {name === 'eye-off' && (
    <Fragment>
      <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
      <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
      <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24" />
      <path d="M1 1l22 22" />
    </Fragment>
  )}
  {name === 'calculator' && (
    <Fragment>
      <rect x="4" y="2" width="16" height="20" rx="2" />
      <line x1="8" y1="6" x2="16" y2="6" />
      <line x1="8" y1="10" x2="9" y2="10" />
      <line x1="12" y1="10" x2="13" y2="10" />
      <line x1="16" y1="10" x2="16" y2="10" />
      <line x1="8" y1="14" x2="9" y2="14" />
      <line x1="12" y1="14" x2="13" y2="14" />
      <line x1="16" y1="14" x2="16" y2="14" />
      <line x1="8" y1="18" x2="9" y2="18" />
      <line x1="12" y1="18" x2="16" y2="18" />
    </Fragment>
  )}
</svg>

<style>
  .icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
