---
import TimelineSteps from './TimelineSteps.astro';

const steps = [
  {
    label: 'Antes',
    icon: 'clock',
    title: '2-3 vasos de agua',
    description: 'Dos horas antes del entreno para que el cuerpo llegue con un nivel de líquidos adecuado.',
    dataPoint: '2 horas antes',
  },
  {
    label: 'Durante',
    icon: 'activity',
    title: 'Agua + electrolitos + carbohidratos',
    description: 'El cuerpo necesita una reposición equilibrada para mantener la producción de energía y la función muscular.',
    product: 'Elite Actimax',
  },
  {
    label: 'Después',
    icon: 'check-circle',
    title: 'Rehidratarse hasta equilibrio',
    description: 'Seguir bebiendo líquidos hasta que el color de tu orina vuelva a estar claro.',
    dataPoint: 'Orina clara',
  },
];
---

<section class="section pillar pillar--hydration" id="hidratacion">
  <div class="section__inner">
    <div class="pillar__header reveal">
      <span class="pillar__number" aria-hidden="true">1</span>
      <div>
        <h2 class="pillar__title">Hidratación Inteligente</h2>
        <p class="pillar__subtitle">La base silenciosa del rendimiento</p>
      </div>
    </div>

    <p class="pillar__intro reveal">La hidratación no es un detalle. Es uno de los factores que más influyen en tu <strong>energía, concentración</strong> y capacidad de sostener el esfuerzo.</p>

    <div class="reveal">
      <TimelineSteps steps={steps} accentColor="var(--color-hydration)" />
    </div>

    <div class="pillar__habit reveal">
      <div class="habit-badge">Mini hábito</div>
      <p class="habit-text">Lleva siempre tu termo y define un ritmo de hidratación.</p>
      <div class="habit-highlight">
        <span class="habit-number">500 ml</span>
        <span class="habit-unit">por cada hora de actividad física</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pillar--hydration {
    background: var(--color-surface);
    border-top: 3px solid var(--color-hydration);
  }

  .pillar__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .pillar__number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-hydration);
    color: white;
    font-size: var(--text-lg);
    font-weight: 900;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    line-height: 1;
  }

  .pillar__title {
    font-size: var(--text-xl);
    margin-bottom: 0.15rem;
  }

  .pillar__subtitle {
    font-size: var(--text-sm);
    color: var(--color-hydration);
    font-weight: 600;
    margin: 0;
  }

  .pillar__intro {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2xl);
    line-height: 1.7;
  }

  /* Mini habit card */
  .pillar__habit {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    background: var(--color-hydration-light);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .habit-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-hydration);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-md);
  }

  .habit-text {
    font-size: var(--text-base);
    color: var(--color-body-text);
    margin-bottom: var(--space-md);
  }

  .habit-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .habit-number {
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--color-hydration);
    line-height: 1;
  }

  .habit-unit {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  @media (max-width: 480px) {
    .pillar__header {
      gap: var(--space-sm);
    }

    .pillar__number {
      width: 40px;
      height: 40px;
      font-size: var(--text-base);
    }

    .pillar__habit {
      padding: var(--space-lg);
    }

    .habit-number {
      font-size: var(--text-xl);
    }
  }
</style>
