---
// Pillar 5: Daily Nutrition
import Icon from './Icon.astro';

const guidelines = [
  { icon: 'clock', text: 'Come cada 3-4 horas', detail: 'para mantener niveles de energía estables.' },
  { icon: 'shield', text: 'Incluye siempre proteína + carbohidrato de calidad', detail: 'en cada comida.' },
  { icon: 'eye-off', text: 'Reduce ultraprocesados', detail: 'en días de mayor carga de entrenamiento.' },
  { icon: 'repeat', text: 'Ten opciones prácticas a la mano', detail: 'para no improvisar.' },
];
---

<section class="section pillar pillar--nutrition" id="nutricion">
  <div class="section__inner">
    <div class="pillar__header reveal">
      <span class="pillar__number">5</span>
      <div>
        <h2 class="pillar__title">Nutrición Diaria</h2>
        <p class="pillar__subtitle">Lo que haces cada día también entrena</p>
      </div>
    </div>

    <p class="pillar__intro reveal">No solo importa lo que comes mientras entrenas. Importa, y mucho, lo que comes <strong>el resto del día.</strong></p>

    <p class="pillar__body reveal">La alimentación diaria es la base sobre la que se apoya tu energía, tu recuperación y tu capacidad de rendir sesión tras sesión. No se trata de extremos, sino de <strong>constancia.</strong></p>

    <ul class="nutrition-list">
      {guidelines.map((g) => (
        <li class="nutrition-item reveal">
          <span class="nutrition-item__icon" aria-hidden="true"><Icon name={g.icon} size={20} /></span>
          <div>
            <strong>{g.text}</strong>
            <span class="nutrition-item__detail">{g.detail}</span>
          </div>
        </li>
      ))}
    </ul>

    <blockquote class="pillar__quote reveal">
      <p>Una nutrición simple, repetible y bien distribuida sostiene más rendimiento que cualquier <strong>estrategia puntual.</strong></p>
    </blockquote>

    <div class="pillar__habit reveal">
      <div class="habit-badge">Mini hábito</div>
      <p class="habit-text"><strong>Un gel en el bolsillo cambia tu entrenamiento.</strong></p>
      <a href="https://actimax.com.co/productos/geles-energeticos/gel-energetico-24-con-cafeina/" target="_blank" rel="noopener" class="habit-product">
        <img src="/gel-energetico.png" alt="Gel Energético Actimax con Cafeína" class="habit-product__img" />
        <div class="habit-product__info">
          <strong>Gel Energético Actimax con Cafeína</strong>
          <p>30g de energía rápida en cada sachet. Práctico, con buen sabor y diseñado para sostener tu rendimiento durante el entreno o la competencia.</p>
          <span class="habit-product__cta">Ver producto &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .pillar--nutrition {
    background: var(--color-warm-yellow);
    border-top: 3px solid var(--color-nutrition);
  }

  .pillar--nutrition .pillar__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .pillar--nutrition .pillar__number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-nutrition);
    color: white;
    font-size: var(--text-lg);
    font-weight: 900;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    line-height: 1;
  }

  .pillar--nutrition .pillar__title {
    font-size: var(--text-xl);
    margin-bottom: 0.15rem;
  }

  .pillar--nutrition .pillar__subtitle {
    font-size: var(--text-sm);
    color: var(--color-nutrition);
    font-weight: 600;
    margin: 0;
  }

  .pillar--nutrition .pillar__intro {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }

  .pillar__body {
    font-size: var(--text-base);
    margin-bottom: var(--space-2xl);
  }

  /* Nutrition guidelines */
  .nutrition-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .nutrition-item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 1px solid rgba(76, 175, 80, 0.15);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s;
  }

  .nutrition-item:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }

  .nutrition-item__icon {
    width: 20px;
    height: 20px;
    color: var(--color-nutrition);
    flex-shrink: 0;
    line-height: 1.5;
  }

  .nutrition-item strong {
    font-size: var(--text-base);
    display: block;
    margin-bottom: 0.15rem;
  }

  .nutrition-item__detail {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* Quote */
  .pillar--nutrition .pillar__quote {
    border-left: 4px solid var(--color-nutrition);
    padding: var(--space-lg) var(--space-xl);
    background: var(--color-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin-bottom: var(--space-2xl);
  }

  .pillar--nutrition .pillar__quote p {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-navy);
  }

  /* Mini habit */
  .pillar--nutrition .pillar__habit {
    padding: var(--space-xl);
    background: var(--color-nutrition-light);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .pillar--nutrition .habit-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-nutrition);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-md);
  }

  .habit-text {
    font-size: var(--text-lg);
    margin-bottom: var(--space-lg);
  }

  .habit-product {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
    border: 2px solid transparent;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s var(--ease-spring);
  }

  .habit-product:hover {
    border-color: var(--color-nutrition);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .habit-product__img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: var(--color-warm-yellow);
    padding: var(--space-xs);
  }

  .habit-product__info strong {
    font-size: var(--text-base);
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-navy);
  }

  .habit-product__info p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
    line-height: 1.4;
  }

  .habit-product__cta {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-nutrition);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .pillar--nutrition .pillar__header {
      gap: var(--space-sm);
    }

    .pillar--nutrition .pillar__number {
      width: 40px;
      height: 40px;
      font-size: var(--text-base);
    }

    .nutrition-item {
      padding: var(--space-md);
      gap: var(--space-sm);
    }

    .pillar--nutrition .pillar__quote {
      padding: var(--space-md) var(--space-lg);
    }

    .pillar--nutrition .pillar__habit {
      padding: var(--space-lg);
    }

    .habit-product {
      flex-direction: column;
      text-align: center;
      padding: var(--space-md);
      gap: var(--space-md);
    }

    .habit-product__img {
      width: 100px;
      height: 100px;
    }

    .habit-product__info strong {
      font-size: var(--text-sm);
    }
  }
</style>
