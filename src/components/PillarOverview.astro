---
// 5 Pillars overview - navigation hub with pillar cards
import Icon from './Icon.astro';

const pillars = [
  { number: 1, name: 'Hidratación inteligente', icon: 'droplet', color: 'var(--color-hydration)', bg: 'var(--color-hydration-light)', href: '#hidratacion' },
  { number: 2, name: 'Energía estratégica', icon: 'zap', color: 'var(--color-energy)', bg: 'var(--color-energy-light)', href: '#energia' },
  { number: 3, name: 'Sueño reparador', icon: 'moon', color: 'var(--color-sleep)', bg: 'var(--color-sleep-light)', href: '#sueno' },
  { number: 4, name: 'Mentalidad de atleta', icon: 'target', color: 'var(--color-mindset)', bg: 'var(--color-mindset-light)', href: '#mentalidad' },
  { number: 5, name: 'Nutrición diaria', icon: 'leaf', color: 'var(--color-nutrition)', bg: 'var(--color-nutrition-light)', href: '#nutricion' },
];
---

<section class="section pillars-overview" id="pilares">
  <div class="section__inner">
    <h2 class="pillars-overview__title reveal">Los 5 Pilares del<br/>Entrenamiento Invisible</h2>
    <p class="pillars-overview__sub reveal">No necesitas hacerlo perfecto. Necesitas hacerlo <strong>con intención.</strong></p>

    <div class="pillar-cards">
      {pillars.map((p, i) => (
        <a href={p.href} class="pillar-card reveal" style={`--card-color: ${p.color}; --card-bg: ${p.bg}; animation-delay: ${i * 0.08}s;`}>
          <span class="pillar-card__number">{p.number}</span>
          <span class="pillar-card__icon" aria-hidden="true" style={`color: var(--card-color);`}>
            <Icon name={p.icon} size={28} />
          </span>
          <span class="pillar-card__name">{p.name}</span>
        </a>
      ))}
    </div>

    <p class="pillars-overview__cta reveal">Elige construirlos poco a poco.<br/><strong>Ahí vive la constancia real.</strong></p>
  </div>
</section>

<style>
  .pillars-overview {
    background: var(--color-warm-yellow);
  }

  .pillars-overview__title {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .pillars-overview__sub {
    text-align: center;
    font-size: var(--text-lg);
    margin-bottom: var(--space-2xl);
    color: var(--color-body-text);
  }

  .pillar-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .pillar-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg) var(--space-md);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s var(--ease-spring), border-color 0.2s, box-shadow 0.2s;
    text-align: center;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-color);
    box-shadow: var(--shadow-md);
  }

  .pillar-card__number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--card-color);
    color: white;
    font-size: var(--text-sm);
    font-weight: 800;
    display: grid;
    place-items: center;
    line-height: 1;
  }

  .pillar-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    line-height: 1;
  }

  .pillar-card__name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.3;
  }

  .pillars-overview__cta {
    text-align: center;
    font-size: var(--text-lg);
  }

  @media (max-width: 480px) {
    .pillar-cards {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }

    .pillar-card {
      padding: var(--space-md) var(--space-sm);
      gap: 0.25rem;
    }

    .pillar-card__number {
      width: 28px;
      height: 28px;
      font-size: var(--text-xs);
    }

    .pillar-card__icon {
      width: 24px;
      height: 24px;
    }

    .pillar-card__name {
      font-size: var(--text-xs);
    }

    /* Center the 5th card on its own row */
    .pillar-card:last-child {
      grid-column: 1 / -1;
      max-width: 180px;
      margin: 0 auto;
    }
  }
</style>
