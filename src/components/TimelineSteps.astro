---
// Reusable Before / During / After timeline component
import Icon from './Icon.astro';

interface Step {
  label: string;
  icon: string;
  title: string;
  description: string;
  dataPoint?: string;
  product?: string;
  productUrl?: string;
}

interface Props {
  steps: Step[];
  accentColor?: string;
}

const { steps, accentColor = 'var(--color-hydration)' } = Astro.props;
---

<div class="timeline" style={`--accent: ${accentColor};`}>
  {steps.map((step, i) => (
    <div class="timeline__step">
      <div class="timeline__marker">
        <span class="timeline__icon" aria-hidden="true"><Icon name={step.icon} size={20} class="timeline-icon-svg" /></span>
        {i < steps.length - 1 && <div class="timeline__line" />}
      </div>
      <div class="timeline__content">
        <span class="timeline__label">{step.label}</span>
        <h4 class="timeline__title">{step.title}</h4>
        <p class="timeline__desc">{step.description}</p>
        {step.dataPoint && (
          <span class="timeline__data">{step.dataPoint}</span>
        )}
        {step.product && step.productUrl ? (
          <a class="timeline__product" href={step.productUrl} target="_blank" rel="noopener noreferrer">{step.product}</a>
        ) : step.product ? (
          <span class="timeline__product">{step.product}</span>
        ) : null}
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline__step {
    display: flex;
    gap: var(--space-md);
    position: relative;
  }

  .timeline__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 48px;
  }

  .timeline__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: grid;
    place-items: center;
    font-size: 1.2rem;
    position: relative;
    z-index: 1;
  }

  .timeline-icon-svg {
    color: white;
  }

  .timeline__line {
    width: 2px;
    flex: 1;
    background: var(--accent);
    opacity: 0.25;
    min-height: 20px;
  }

  .timeline__content {
    padding-bottom: var(--space-xl);
    flex: 1;
  }

  .timeline__label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: var(--space-xs);
  }

  .timeline__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .timeline__desc {
    font-size: var(--text-base);
    color: var(--color-body-text);
    line-height: 1.6;
  }

  .timeline__data {
    display: inline-block;
    margin-top: var(--space-sm);
    padding: 0.3rem 0.8rem;
    background: var(--color-warm-yellow);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-navy);
  }

  .timeline__product {
    display: inline-block;
    margin-top: var(--space-sm);
    margin-left: var(--space-sm);
    padding: 0.3rem 0.8rem;
    background: var(--color-navy);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-golden);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  a.timeline__product:hover {
    opacity: 0.85;
  }

  @media (max-width: 480px) {
    .timeline__step {
      gap: var(--space-sm);
    }

    .timeline__marker {
      width: 40px;
    }

    .timeline__icon {
      width: 40px;
      height: 40px;
      font-size: 1rem;
    }

    .timeline__title {
      font-size: var(--text-base);
    }

    .timeline__desc {
      font-size: var(--text-sm);
    }

    .timeline__content {
      padding-bottom: var(--space-lg);
    }

    .timeline__product,
    .timeline__data {
      font-size: var(--text-xs);
      padding: 0.25rem 0.6rem;
    }

    .timeline__product {
      margin-left: 0;
      margin-top: var(--space-xs);
    }
  }

  @media (min-width: 640px) {
    .timeline {
      flex-direction: row;
      gap: var(--space-md);
    }

    .timeline__step {
      flex-direction: column;
      flex: 1;
      align-items: center;
      text-align: center;
    }

    .timeline__marker {
      flex-direction: row;
      width: 100%;
      justify-content: center;
    }

    .timeline__line {
      width: auto;
      height: 2px;
      flex: 1;
      min-height: unset;
    }

    .timeline__content {
      padding-bottom: 0;
    }
  }
</style>
